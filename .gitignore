# ─────────────────────────────────────────────────────────────────────────────
# VoiceSplit .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo
next-env.d.ts

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Data & Uploads ────────────────────────────────────────────────────────────
data/
uploads/
temp/
tmp/
docker/data/

# ── Alembic ───────────────────────────────────────────────────────────────────
# Track migration scripts but not __pycache__ inside
alembic/versions/__pycache__/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace

# ── Docker ────────────────────────────────────────────────────────────────────
docker/data/

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.bak
*.orig
*.patch
.cache/
.parcel-cache/
